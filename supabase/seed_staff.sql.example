-- Companion to supabase/seed.sql — staff membership seeding.
--
-- staff_memberships.user_id references auth.users(id), which Supabase Auth
-- owns. Create the 4 demo accounts first (dashboard or Admin API — see
-- README below), then replace the placeholder UUIDs here with the real ones
-- and run this against the project (psql, Supabase Studio SQL editor, or
-- `supabase db execute` once you have the CLI).
--
-- Demo Card Retailer organisation_id: 58a5ac20-5aa2-43d8-be60-274e9d8de220
-- Look up current fulfilment_node ids with:
--   select id, name, code from fulfilment_nodes where organisation_id = '58a5ac20-5aa2-43d8-be60-274e9d8de220';

insert into staff_memberships (organisation_id, user_id, role_code, scope_type)
values
  -- Admin — full org access
  ('58a5ac20-5aa2-43d8-be60-274e9d8de220', '<ADMIN_USER_ID>', 'owner', 'organisation'),
  -- Pricing user — pricing decisions are org-wide, not store-scoped
  ('58a5ac20-5aa2-43d8-be60-274e9d8de220', '<PRICING_USER_ID>', 'pricing_manager', 'organisation');

-- Store manager — scoped to Geelong (STR-01).
insert into staff_memberships (organisation_id, user_id, role_code, scope_type, fulfilment_node_id)
values ('58a5ac20-5aa2-43d8-be60-274e9d8de220', '<STORE_MANAGER_USER_ID>', 'store_manager', 'store', '<GEELONG_NODE_ID>');

-- Inventory manager — scoped to Bendigo (STR-02).
insert into staff_memberships (organisation_id, user_id, role_code, scope_type, fulfilment_node_id)
values ('58a5ac20-5aa2-43d8-be60-274e9d8de220', '<INVENTORY_USER_ID>', 'inventory_manager', 'store', '<BENDIGO_NODE_ID>');
