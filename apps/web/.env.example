# Supabase (browser-safe values only — never put the service-role key here
# or in any NEXT_PUBLIC_* variable; see AGENTS.md rule 3).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Stripe (server-side only)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Typesense (search, B-021/B-084). Server-side only — the search API route
# proxies all queries, so no Typesense key is ever sent to the browser.
# For local dev: docker compose up typesense (see docker-compose.yml).
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=local-dev-typesense-key
