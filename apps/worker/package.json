{
  "name": "worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "enqueue-catalogue-import": "tsx src/scripts/enqueue-catalogue-import.ts",
    "reindex-search": "tsx src/scripts/reindex-search.ts",
    "update-popularity-scores": "tsx src/scripts/update-popularity-scores.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint",
    "test": "vitest run",
    "load-test": "tsx src/load-test/index.ts"
  },
  "dependencies": {
    "@probable-winner/search": "workspace:*",
    "@sentry/node": "^10.67.0",
    "@supabase/supabase-js": "^2.110.8",
    "justtcg-js": "^0.2.1",
    "mtggraphql": "^1.0.2",
    "postgres": "^3.4.7",
    "typesense": "^3.0.6"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "tsx": "^4.20.7",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.4",
    "vitest": "^4.1.10"
  }
}
