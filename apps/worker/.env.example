# Direct Postgres connection string for the Supabase project (Session Pooler
# or direct connection, NOT the anon/publishable REST key). The worker talks
# to Postgres directly — it is a trusted backend process, not browser code.
# Find it in Supabase Dashboard > Project Settings > Database.
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# Typesense (search, B-021/B-084). Used by the reindex/update-popularity-scores
# scripts and the search_index queue consumer. For local dev: docker compose
# up typesense (see docker-compose.yml at the repo root).
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=local-dev-typesense-key
